{
  "name": "cursor-linkup-mcp",
  "private": true,
  "description": "Root npm helpers for Stitch dev. UI runs from stitch-app (see docs/stitch/MIGRATION.md). Optional STITCH_APP_ROOT=path/to/stitch-app. Bundled GUI still uses Python in this repo.",
  "scripts": {
    "dev:browser": "node scripts/run-stitch-ui.mjs dev:browser",
    "dev:desktop": "node scripts/run-stitch-ui.mjs dev",
    "launch:stitch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-StitchDesktop.ps1",
    "launch:stitch:ui-only": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-StitchDesktop.ps1 -SkipBridge",
    "build:stitch-app": "node scripts/run-stitch-ui.mjs tauri build",
    "build:stitch-web": "node scripts/run-stitch-ui.mjs build",
    "gui:stitch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-Stitch.ps1 -Mode Bundled",
    "stitch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-Stitch.ps1 -Mode Bundled",
    "stitch:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-Stitch.ps1 -Mode TauriDev"
  }
}
