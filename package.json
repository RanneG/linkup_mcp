{
  "name": "cursor-linkup-mcp",
  "private": true,
  "description": "Root npm helpers for linkup_mcp. Stitch app launch is owned by stitch-app repo.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:browser": "node scripts/run-stitch-ui.mjs dev:browser",
    "dev:desktop": "node scripts/run-stitch-ui.mjs dev",
    "build:stitch-app": "node scripts/run-stitch-ui.mjs tauri build",
    "build:stitch-web": "node scripts/run-stitch-ui.mjs build",
    "build:stitch-api-types": "npm run build -w stitch-api-types"
  }
}
