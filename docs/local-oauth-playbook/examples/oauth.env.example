# Copy to .env next to your bridge/server (never commit real values).
# Google Cloud → Credentials → OAuth 2.0 Client IDs (Web application).

GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# Optional: must match an Authorized redirect URI in Console exactly.
# STITCH_GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/api/auth/google/callback
