# Copy to VPS: ~/.hermes/.env (Hermes gateway reads this)
# Same NAMI_BUILD_TOKEN must be in PC linkup_mcp/.env

# PC Tailscale IP when bridge listens on 0.0.0.0 (see MOBILE_BUILD.md)
NAMI_BUILD_PC_URL=http://100.x.x.x:8770
NAMI_BUILD_TOKEN=paste-same-value-as-pc-dot-env

# On home LAN without Tailscale you can use PC LAN IP instead:
# NAMI_BUILD_PC_URL=http://192.168.x.x:8770

# After editing on VPS:
#   cd ~/Cursor/linkup_mcp && bash scripts/install-nami-hermes.sh && hermes gateway restart
